{
  "extends": "./tsconfig.json",
  // Flatten output in the dist directory so `src` is not included in the path
  "compilerOptions": { "rootDir": "./src" },
  // Do not include the test files
  "include": ["src/**/*.ts"],
  // Exclude ambient module declaration so it doesn't leak to consumers
  "exclude": ["src/medic-constants.d.ts"],
}
